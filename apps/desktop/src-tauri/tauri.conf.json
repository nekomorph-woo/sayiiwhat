{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sayiiwhat",
  "version": "0.2.1",
  "identifier": "com.morphiiouo.sayiiwhat",
  "build": {
    "beforeDevCommand": "./node_modules/.bin/vite --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "./node_modules/.bin/tsc && ./node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sayiiwhat",
        "width": 1428,
        "height": 1030,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/bin/README.md"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
